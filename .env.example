# ── API Server (Render / Railway / any Node host) ───────────────────────────

# Supabase connection string — copy from Supabase dashboard:
#   Project → Settings → Database → Connection string → URI
# Use the "Transaction mode" pooler URL (port 6543) for serverless,
# or the direct connection (port 5432) for a long-running server.
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Anthropic API key — https://console.anthropic.com/settings/keys
# OpenAI API key, used first for interview turns and insights.
OPENAI_API_KEY=sk-proj-...
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4.1-nano
OPENAI_FALLBACK_MODELS=gpt-4.1-mini,gpt-4o-mini
OPENAI_TIMEOUT_MS=12000

# Anthropic API key, optional fallback if OpenAI is unavailable.
ENABLE_ANTHROPIC_FALLBACK=false
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_FALLBACK_MODELS=claude-3-5-haiku-20241022,claude-3-haiku-20240307

# A long random string used to sign session cookies.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed frontend origins (no trailing slash).
# Set to your Vercel deployment URL in production.
ALLOWED_ORIGINS=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

NODE_ENV=production
PORT=8080

# ─── HeyGen (AI avatar — optional) ───────────────────────────────────────────
LIVEAVATAR_API_KEY=sk_V2_...

# ─── Email (SMTP — optional) ──────────────────────────────────────────────────
# Email via HTTPS API (recommended for Render Free)
RESEND_API_KEY=re_...
EMAIL_FROM=Insightly <onboarding@resend.dev>

# SMTP fallback (works locally or on hosts that allow SMTP ports)
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# ── Frontend (add these in Vercel project → Settings → Environment Variables) ─

# Full URL of the deployed API server — no trailing slash.
# Leave blank when frontend and backend share the same domain/proxy.
VITE_API_URL=https://insightly-api.onrender.com
